# Feature flags (server-side parsers / ingest)
ENABLE_DOORDASH=false
ENABLE_SKIP=false

# Google Maps (Distance Matrix)
GOOGLE_MAPS_API_KEY=

# Python API (local Vercel Python runtime)
PYTHON_API_URL=http://localhost:3001
